config I2C_RPI_PICO_PIO
	bool "Raspberry Pi PICO PIO I2C controller driver"
	default y
	depends on DT_HAS_RASPBERRYPI_PICO_I2C_PIO_ENABLED
	select PICOSDK_USE_PIO
	select PICOSDK_USE_CLAIM
	help
	  Enable driving I2C via PIO on the PICO
